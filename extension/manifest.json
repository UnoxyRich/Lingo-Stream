{
  "manifest_version": 3,
  "name": "YouTube Immersion Mode",
  "version": "0.1.0",
  "description": "Replace meaningful subtitle words on YouTube with translated equivalents.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://libretranslate.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
