{
  "manifest_version": 3,
  "name": "YouTube Immersion Mode",
  "version": "0.1.0",
  "description": "Replace meaningful subtitle words on YouTube with translated equivalents.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://libretranslate.com/*",
    "https://translate.argosopentech.com/*",
    "https://apertium.org/*",
    "https://beta.apertium.org/*",
    "https://api.mymemory.translated.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "captionObserver.js",
        "logger.js",
        "translation.js",
        "stopwords.js",
        "processor.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
