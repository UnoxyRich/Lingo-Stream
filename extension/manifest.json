{
  "manifest_version": 3,
  "name": "Lingo Stream",
  "version": "0.1.0",
  "description": "Replace meaningful subtitle words on YouTube with translated equivalents.",
  "permissions": [
    "storage",
    "downloads",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://youtube.com/*",
    "https://www.youtube.com/*",
    "https://m.youtube.com/*",
    "https://translate.googleapis.com/*",
    "https://libretranslate.com/*",
    "https://translate.argosopentech.com/*",
    "https://apertium.org/*",
    "https://beta.apertium.org/*",
    "https://api.mymemory.translated.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "logo.svg",
    "32": "logo.svg",
    "48": "logo.svg",
    "128": "logo.svg"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "logo.svg",
      "32": "logo.svg",
      "48": "logo.svg"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://youtube.com/*",
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": [
        "captionObserver.js",
        "logger.js",
        "translation.js",
        "stopwords.js",
        "processor.js",
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
